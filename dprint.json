{
  "markdown": {
    "lineWidth": 80,
    "textWrap": "always",
    "emphasisKind": "underscores",
    "strongKind": "asterisks",
    "unorderedListKind": "dashes",
    "headingKind": "atx",
    "listIndentKind": "commonMark"
  },
  "includes": [
    "*.md"
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.22.0.wasm",
  ]
}